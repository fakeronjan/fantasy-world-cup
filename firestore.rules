rules_version = '2';

// Fantasy World Cup — Firestore security rules.
//
// Principles:
//   - Everyone signed in can READ everything (leaderboard transparency).
//   - Users can WRITE only their own `users/{uid}` doc, and only when the
//     game state allows (pre-kickoff for draft, transfer windows for swaps).
//   - All catalog data (teams, players, matches, config, leaderboard) is
//     writable only by admin accounts. Admin writes happen via the
//     server-side Firebase Admin SDK (used by GitHub Actions ingest +
//     reprice scripts), which bypasses these rules entirely via the
//     service-account key — so the rules just need to lock out everyone
//     who isn't an admin from the client side.

service cloud.firestore {
  match /databases/{database}/documents {

    // ---- helpers -------------------------------------------------------
    function isSignedIn() {
      return request.auth != null;
    }
    function isAdmin() {
      // Mirror this list with ADMIN_UIDS in docs/shared.js (used to gate
      // UI links). Both must match for admin powers to work end-to-end.
      return isSignedIn() && request.auth.uid in [
        'mixdmNZGD3YnzSFOJ077AKfQKXL2',  // rjsikdar@gmail.com
      ];
    }
    function configDoc() {
      return get(/databases/$(database)/documents/config/global).data;
    }
    function beforeKickoff() {
      let cfg = configDoc();
      // Treat null kickoff as "kickoff hasn't been set yet" → still pre-kickoff.
      // Once an admin sets config.kickoffTimestamp, this auto-locks at that moment.
      return cfg.kickoffTimestamp == null || request.time < cfg.kickoffTimestamp;
    }
    function transferWindowOpen() {
      return configDoc().transferWindowOpen == true;
    }

    // ---- users ---------------------------------------------------------
    // A user can read/write their own doc. Roster edits allowed only
    // pre-kickoff (initial draft) or during a transfer window.
    match /users/{uid} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == uid;
      allow update: if isSignedIn() && (
                       // Owner editing their own doc, subject to game-state gates
                       (request.auth.uid == uid
                        && (beforeKickoff() || transferWindowOpen()
                            || onlyTouchesProfileFields()))
                       // Admin can edit any user doc, any time (league management)
                       || isAdmin()
                     );
      allow delete: if isAdmin();
    }
    function onlyTouchesProfileFields() {
      // Allow harmless updates (e.g., displayName refresh) outside transfer
      // windows. Block any roster/budget edits.
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      return !changed.hasAny(['roster', 'currentBudget', 'totalSpent']);
    }

    // ---- catalog (admin-only writes) ----------------------------------
    match /teams/{teamId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    match /players/{playerId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    match /matches/{matchId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    match /config/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    match /leaderboard/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ---- transactions (audit log; users append their own) -------------
    match /transactions/{txId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
                    && request.resource.data.uid == request.auth.uid
                    && (beforeKickoff() || transferWindowOpen());
      allow update, delete: if false; // immutable
    }

    // ---- flag knockout (fun side contest) -----------------------------
    // Bracket state is admin-only write, everyone-read. Winners/tallies are
    // written into it ONLY when the admin closes a round, which is what makes
    // results "hidden until close".
    match /flagContest/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    function flagState() {
      return get(/databases/$(database)/documents/flagContest/state).data;
    }
    // Votes: one doc per user per game (id = "<round>__<gameId>__<uid>"). A user
    // can read/write only their OWN vote — so nobody can scrape the live tally
    // mid-round. The admin (via SDK or admin uid) reads all to tally at close.
    match /flagVotes/{voteId} {
      allow read: if isAdmin()
                  || (isSignedIn() && resource.data.uid == request.auth.uid);
      allow create, update: if isSignedIn()
                    && request.resource.data.uid == request.auth.uid
                    && request.resource.data.choice in ['a', 'b']
                    && flagState().votingOpen == true
                    && request.resource.data.round == flagState().currentRound;
      allow delete: if false;
    }
  }
}
